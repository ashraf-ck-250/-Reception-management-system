PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/reception_management
JWT_SECRET=change_this_to_a_long_random_secret

# Email (SMTP) — use a real .env file; Gmail needs 2FA + App Password (16 chars, no spaces in SMTP_PASS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_account@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM="ReceptionMS <your_account@gmail.com>"

# Frontend base URL for email links
FRONTEND_BASE_URL=http://localhost:8080
